# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=ummbsummer.com

# URLs (used for OAuth redirect URIs and CORS)
# Dev:  BACKEND_URL=http://localhost:8000  FRONTEND_URL=http://localhost:5173
# Prod: both set to https://ummbsummer.com
BACKEND_URL=https://ummbsummer.com
FRONTEND_URL=https://ummbsummer.com

# Database
DATABASE_NAME=ummbsummer
DATABASE_USER=ummbsummer
DATABASE_PASSWORD=change-me

# Google OAuth
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret

# Strava OAuth & Webhooks
STRAVA_CLIENT_ID=strava-client-id
STRAVA_CLIENT_SECRET=strava-client-secret
STRAVA_WEBHOOK_ENDPOINT_TOKEN=strava-webhook-endpoint-token
STRAVA_WEBHOOK_VERIFY_TOKEN=strava-webhook-verify-token
STRAVA_WEBHOOK_SUBSCRIPTION_ID=strava-webhook-subscription-id

# Challenge timing (Unix timestamps)
START_DATE_EPOCH_TIME=start-date-epoch-time
END_DATE_EPOCH_TIME=end-date-epoch-time

# Mapbox (for activity map image generation)
MAPBOX_ACCESS_TOKEN=mapbox-access-token
