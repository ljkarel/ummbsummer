{
  "name": "ummbsummer",
  "dockerComposeFile": ["../docker-compose.yml", "../docker-compose.dev.yml"],
  "service": "django",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "forwardPorts": [8000, 5173, 5432, 6379],
  "portsAttributes": {
    "8000": { "label": "Django" },
    "5173": { "label": "Vite (frontend)" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" }
  }
}
